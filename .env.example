APP_NAME="aether-viz-service"
APP_ENV="local"
APP_HOST="0.0.0.0"
APP_PORT="10095"
LOG_LEVEL="INFO"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
PLANNING_OPENAI_API_KEY=""
PLANNING_OPENAI_BASE_URL=""
PLANNING_OPENAI_MODEL="deepseek-v4-flash"
PLANNING_REASONING_EFFORT="medium"
AETHERVIZ_PLAN_MODEL="deepseek-v4-flash"
AETHERVIZ_HTML_MODEL="deepseek-v4-flash"
AETHERVIZ_REPAIR_MODEL="qwen3.7-plus"
AETHERVIZ_GSAP_CDN_URL="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"
AETHERVIZ_MAX_REPAIR_ATTEMPTS="1"
AETHERVIZ_PLAN_TIMEOUT_SECONDS="180"
AETHERVIZ_PLAN_MAX_RETRIES="1"
AETHERVIZ_HTML_TIMEOUT_SECONDS="600"
AETHERVIZ_HTML_MAX_RETRIES="1"
AETHERVIZ_REPAIR_TIMEOUT_SECONDS="300"
AETHERVIZ_REPAIR_MAX_RETRIES="1"
AETHERVIZ_HTML_ENABLE_THINKING="false"
# AETHERVIZ_HTML_REASONING_EFFORT="medium"

# LangSmith 可观测性（LangChain 模型调用自动上报 trace）
LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=""
# 组织级 API Key 需指定工作区 ID 时启用：
# LANGSMITH_WORKSPACE_ID=""

# 如需切换到其他 OpenAI-compatible 服务，只需替换同一组配置：
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4.1-mini"

# 教学方案 plan/revise 阶段默认使用 deepseek-v4-flash 单次 LLM 调用。
# PLANNING_REASONING_EFFORT 可选 low / medium / high，用于开启推理模式提升方案质量。
# HTML 直出阶段默认关闭推理（AETHERVIZ_HTML_ENABLE_THINKING=false）：推理内容不会展示给用户，
# 且推理与正文共享 completion token 预算，开启后实测会显著增加耗时并提高截断概率；
# 如需在直出阶段实验推理模式，请先单独评估耗时和截断率变化。
# PLANNING_OPENAI_API_KEY 和 PLANNING_OPENAI_BASE_URL 留空时会复用 OPENAI_* 配置。
# 如使用百炼业务空间专属地址，可设置：
# PLANNING_OPENAI_BASE_URL="https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1"
