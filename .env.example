# OpenAI-compatible 服务的 API 密钥；规划、路由、生成、编辑和修复共用，禁止提交真实值。
OPENAI_API_KEY=""
# OpenAI-compatible 服务的基础地址；所有模型请求共用。
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# 教学课件规划阶段使用的模型名称。
OPENAI_PLAN_MODEL="deepseek-v4-flash"
# 模糊 IR 路由短 JSON 仲裁使用的模型名称。
OPENAI_ROUTER_MODEL="deepseek-v4-flash"
# 新 HTML、几何 IR 和完整 HTML 编辑使用的模型名称。
OPENAI_HTML_MODEL="qwen3.7-plus"
# 函数级修复和整页 HTML 修复使用的模型名称。
OPENAI_REPAIR_MODEL="deepseek-v4-flash"
# 编辑需求诊断与消歧使用的模型名称；仅输出短 JSON，不生成 HTML。
OPENAI_EDIT_ANALYSIS_MODEL="deepseek-v4-flash"
# 是否启用模型辅助的模糊 IR 路由；关闭后仅使用确定性路由。
AETHERVIZ_IR_ROUTER_ENABLED=true
# 是否启用 IR 路由影子模式；开启时仅记录模型结论，实际仍采用确定性首选。
AETHERVIZ_IR_ROUTER_SHADOW_MODE=true
# 单次 IR 路由短 JSON 响应允许输出的最大 token 数。
AETHERVIZ_IR_ROUTER_MAX_TOKENS=768
# 单次 IR 路由模型请求的超时时间，单位为秒。
AETHERVIZ_IR_ROUTER_TIMEOUT_SECONDS=20
# IR 路由模型请求失败后的最大重试次数。
AETHERVIZ_IR_ROUTER_MAX_RETRIES=1
# 接受模型 IR 路由结论所需的最低置信度，取值范围为 0～1。
AETHERVIZ_IR_ROUTER_CONFIDENCE_THRESHOLD=0.70
# 直接采用确定性 IR 路由所需的最低置信度，取值范围为 0～1。
AETHERVIZ_IR_ROUTER_DETERMINISTIC_THRESHOLD=0.80
# IR 路由第一候选相对第二候选所需的最小分差，取值范围为 0～1。
AETHERVIZ_IR_ROUTER_MIN_MARGIN=0.20
# 教学课件计划 JSON 允许输出的最大 token 数。
AETHERVIZ_PLAN_MAX_TOKENS=3072
# 编辑诊断短 JSON 允许输出的最大 token 数。
AETHERVIZ_EDIT_ANALYSIS_MAX_TOKENS=2048
# 单次编辑诊断模型请求的超时时间，单位为秒。
AETHERVIZ_EDIT_ANALYSIS_TIMEOUT_SECONDS=30
# 编辑诊断模型请求失败后的最大重试次数。
AETHERVIZ_EDIT_ANALYSIS_MAX_RETRIES=1

# GSAP core UMD 脚本地址；只接受不含凭据、query 或 fragment 的 HTTPS URL。
AETHERVIZ_GSAP_CDN_URL="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"
# 是否启用 KaTeX 数学公式渲染；仅在计划包含公式时按需加载，关闭后不加载 KaTeX CDN。
AETHERVIZ_KATEX_ENABLED=true
# KaTeX 样式表 CDN；只接受不含凭据、query 或 fragment 的 HTTPS URL。
AETHERVIZ_KATEX_CSS_URL="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
# KaTeX JavaScript CDN；只接受不含凭据、query 或 fragment 的 HTTPS URL。
AETHERVIZ_KATEX_JS_URL="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"
# 新生成完整 HTML 允许输出的最大 token 数；必须满足服务定义的完整 HTML 最低预算。
AETHERVIZ_HTML_MAX_TOKENS=16384
# HTML 流式传输中断或缺失完整结束标签后的整次重新生成次数。
AETHERVIZ_HTML_STREAM_MAX_RETRIES=1
# 单次三候选重排 Scene IR 响应允许输出的最大 token 数。
AETHERVIZ_SCENE_MAX_TOKENS=12288
# 基于当前 HTML 进行整页编辑时允许输出的最大 token 数。
AETHERVIZ_EDIT_MAX_TOKENS=16384
# 完整 HTML 编辑的采样温度；0.15 在动画改造能力与代码稳定性之间取平衡。
AETHERVIZ_EDIT_TEMPERATURE=0.15
# 完整编辑原样返回、截断或破坏核心契约时的整次重试次数。
AETHERVIZ_EDIT_MAX_RETRIES=1
# HTML 编辑独立启用推理；不影响新 HTML 生成、几何 IR 或修复模型。
AETHERVIZ_EDIT_ENABLE_THINKING=true
# 完整 HTML 编辑模型的可选推理强度；留空时使用模型默认值。
AETHERVIZ_EDIT_REASONING_EFFORT=""
# 整页模型修复允许输出的最大 token 数；必须满足服务定义的完整 HTML 最低预算。
AETHERVIZ_REPAIR_MAX_TOKENS=16384
# 整页模型修复次数；0 关闭，必须为非负整数。
AETHERVIZ_MAX_REPAIR_ATTEMPTS=1
